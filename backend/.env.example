# Neon PostgreSQL pooled connection URL (used at runtime)
# Get this from your Neon project dashboard → Connection Details → Pooled connection
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/chatv1?sslmode=require&pgbouncer=true&connect_timeout=15

# Neon PostgreSQL direct (unpooled) connection URL (used by Prisma migrations)
# Get this from your Neon project dashboard → Connection Details → Direct connection
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/chatv1?sslmode=require

JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
PORT=3001
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
