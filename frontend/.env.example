# Leave empty in development — the Vite dev server proxy handles it.
# In production (Cloudflare Pages), set this to your Cloudflare Worker URL:
# VITE_API_URL=https://blockchat-api.your-subdomain.workers.dev
VITE_API_URL=

# Cloudflare deployment runs in REST polling mode by default.
# Set these explicitly in Pages so the behavior is obvious from the dashboard.
VITE_REALTIME_ENABLED=false
VITE_FILE_UPLOADS_ENABLED=false
VITE_POLL_INTERVAL_MS=5000
